# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it contains secrets).

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Database
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# Server
PORT=
JWT_SECRET=
CORS_ALLOWED_ORIGINS=

# Email (SMTP)
SMTP_USER=
SMTP_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend (Vite)
VITE_GOOGLE_CLIENT_ID=

# Gemini (AI)
# (Legacy misspelling kept for backward compatibility)
GEMENI_API_KEY=
GEMINI_MODEL=
GEMINI_API_VERSION=
GEMINI_API_KEY=
APP_AI_LOG_GEMINI_MARKDOWN=false
